# Required: YouTube Data API v3 key.
YOUTUBE_API_KEY=replace_with_youtube_data_api_key

# Required for production-quality summaries. Without this, the app uses a local extractive fallback.
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_OUTPUT_TOKENS=6000

# Required for Notion sync. Either provide an existing database ID or a parent page ID.
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=
NOTION_DATABASE_TITLE=YouTube Channel Knowledge Base
NOTION_VERSION=2022-06-28
NOTION_INCLUDE_TRANSCRIPT=true

# Default run settings.
CHANNEL_URL=https://youtube.com/@macamp0817?si=U7FfYoWVQQLMvJf0
LANGUAGES=ja,en
TRANSLATE_TO=
MAX_VIDEOS=0
OUTPUT_DIR=data/runs/latest
